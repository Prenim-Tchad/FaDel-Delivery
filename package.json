{
  "type": "module",
  "name": "fadel-api",
  "version": "1.0.0",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "server": "nodemon src/server.js",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "mobile": "cd mobile && flutter run",
    "dev": "docker-compose up -d && nodemon src/server.js",
    "stop": "docker-compose down",
    "fadel": "npm run dev & npm run mobile",
    "test": "jest --runInBand --detectOpenHandles"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@prisma/config": "^7.7.0",
    "@prisma/internals": "^7.7.0",
    "axios": "^1.15.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^16.0.0",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.0",
    "nodemailer": "^8.0.5",
    "pg": "^8.20.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "prisma": "^7.7.0",
    "semver": "^7.7.4",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}
