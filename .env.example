# Database Config (Copy to .env and change values)
DB_USER=your_user
DB_PASSWORD=your_password
DB_NAME=fadel_delivery
DB_HOST=db
DB_PORT=5432
DATABASE_URL=postgresql://your_user:your_password@db:5432/fadel_delivery?schema=public
SHADOW_DATABASE_URL=postgresql://your_user:your_password@db:5432/postgres?schema=public

# Security
JWT_SECRET=your_jwt_secret_key

VERIFY_URL="http://localhost:3000/verify-email"


# SMTP configuration (used to send staff account creation emails)
SMTP_HOST=send.one.com
SMTP_PORT=000
SMTP_SECURE=true
SMTP_USER=adresse@entreprise.org
SMTP_PASSWORD=password
MAIL_FROM="ConnectBiz <adresse@entreprise.org>"

# Node Environment
PORT=3000
