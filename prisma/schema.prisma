datasource db {
  provider = "postgresql"
  //adapter  = "postgresql"
  
}

generator client {
  provider = "prisma-client-js"
}


// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  CLIENT
  RIDER
  PARTNER
  ADMIN
  OWNER
}

enum VehicleType {
  MOTO
  TAXI
  SMALL_TRUCK
  LARGE_TRUCK
}

enum DriverStatus {
  ACTIVE
  WARNING
  SUSPENDED
  BANNED
}

enum PartnerType {
  RESTAURANT
  GAS_STORE
}

enum ServiceType {
  RESTAURANT
  PACKAGE
  GAS
  TAXI
  MOVING
}

enum OrderStatus {
  PENDING
  ACCEPTED
  ON_THE_WAY
  COMPLETED
  CANCELED
}

enum SanctionType {
  WARNING
  SUSPENSION
  BAN
}

// ─────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────

model User {
  id                       String          @id @default(uuid())
  firstname                String?
  lastname                 String?
  phone                    String?         @unique
  email                    String          @unique
  password                 String
  role                     Role            @default(CLIENT)
  isEmailVerified          Boolean         @default(false)
  verificationCodeHash     String?
  verificationCodeExpiresAt DateTime?
  resetPasswordToken       String?
  resetPasswordExpiresAt   DateTime?
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt

  // Relations
  driverProfile            DriverProfile?
  partnerProfile           Partner?
  orders                   Order[]         @relation("ClientOrders")
  sanctions                Sanction[]
}

// ─────────────────────────────────────────────
// DRIVER PROFILE
// ─────────────────────────────────────────────

model DriverProfile {
  id           String       @id @default(uuid())
  userId       String       @unique
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicleType  VehicleType
  licensePlate String?
  isAvailable  Boolean      @default(true)
  status       DriverStatus @default(ACTIVE)
  position     Json?        // { lat: Float, lng: Float }
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  orders       Order[]      @relation("DriverOrders")
}

// ─────────────────────────────────────────────
// PARTNER  (base "class" — polymorphic parent)
// Strategy: Table-Per-Hierarchy
//   • All common partner fields live here
//   • `type` is the discriminator
//   • Restaurant / GasStore hold ONLY their specific data
// ─────────────────────────────────────────────

model Partner {
  id          String      @id @default(uuid())
  userId      String      @unique
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        PartnerType                       // discriminator
  storeName   String
  address     String?
  position    Json?        // { lat: Float, lng: Float }
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Child extensions (only one will be non-null depending on `type`)
  restaurant  Restaurant?
  gasStore    GasStore?

  orders      Order[]     @relation("PartnerOrders")
}

// ─────────────────────────────────────────────
// RESTAURANT  (extends Partner where type = RESTAURANT)
// ─────────────────────────────────────────────

model Restaurant {
  id          String   @id @default(uuid())
  partnerId   String   @unique
  partner     Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  // Restaurant-specific fields
  cuisineType String?               // e.g. "Italian", "African", "Fast Food"
  openingTime String?               // e.g. "08:00"
  closingTime String?               // e.g. "22:00"
  deliveryFee Float    @default(0)
  minOrderAmount Float @default(0)
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  menus       Menu[]
  dishes      Dish[]
}

// ─────────────────────────────────────────────
// GAS STORE  (extends Partner where type = GAS_STORE)
// ─────────────────────────────────────────────

model GasStore {
  id            String   @id @default(uuid())
  partnerId     String   @unique
  partner       Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  // GasStore-specific fields
  availableBrands String[]            // e.g. ["Total", "Shell"]
  hasDelivery     Boolean  @default(true)
  imageUrl        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  gasBottles      GasBottle[]
}

// ─────────────────────────────────────────────
// RESTAURANT — MENU  (a Menu groups Dishes)
// ─────────────────────────────────────────────

model Menu {
  id           String     @id @default(uuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name         String                             // e.g. "Lunch Menu", "Breakfast"
  description  String?
  imageUrl     String?
  isAvailable  Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  menuDishes   MenuDish[]                         // M-N join table with Restaurant Dishes
}

// ─────────────────────────────────────────────
// RESTAURANT — DISH  (individual plate / item)
// ─────────────────────────────────────────────

model Dish {
  id           String     @id @default(uuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  price        Float
  imageUrl     String?
  isAvailable  Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  menuDishes   MenuDish[]
  orderItems   OrderItem[]
}

/// ─────────────────────────────────────────────
// DISH — SUPPLEMENT (Définition du supplément)
// ─────────────────────────────────────────────
model Supplement {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Float
  imageUrl    String?
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relation vers la table de liaison
  menuDishLinks MenuDishSupplement[]
}

// ─────────────────────────────────────────────
// M-N JOIN: Menu ↔ Dish
// ─────────────────────────────────────────────
model MenuDish {
  menuId String
  dishId String
  menu   Menu   @relation(fields: [menuId], references: [id], onDelete: Cascade)
  dish   Dish   @relation(fields: [dishId], references: [id], onDelete: Cascade)

  // On remplace "Supplement[]" par la table de liaison
  supplements MenuDishSupplement[]

  @@id([menuId, dishId])
}

// ─────────────────────────────────────────────
// Table de liaison explicite (Celle qui règle ton erreur)
// ─────────────────────────────────────────────
model MenuDishSupplement {
  menuId       String
  dishId       String
  supplementId String

  // Relation vers MenuDish en utilisant sa clé composée (menuId + dishId)
  menuDish     MenuDish   @relation(fields: [menuId, dishId], references: [menuId, dishId])
  
  // Relation vers Supplement
  supplement   Supplement @relation(fields: [supplementId], references: [id])

  @@id([menuId, dishId, supplementId]) // Clé primaire triple
}
// ─────────────────────────────────────────────
// GAS STORE — GAS BOTTLE
// ─────────────────────────────────────────────

model GasBottle {
  id          String    @id @default(uuid())
  gasStoreId  String
  gasStore    GasStore  @relation(fields: [gasStoreId], references: [id], onDelete: Cascade)
  brand       String
  weightKg    Float
  price       Float
  isAvailable Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  orderItems  OrderItem[]
}

// ─────────────────────────────────────────────
// ORDER
// ─────────────────────────────────────────────

model Order {
  id          String      @id @default(uuid())
  clientId    String
  client      User        @relation("ClientOrders", fields: [clientId], references: [id])
  partnerId   String
  partner     Partner     @relation("PartnerOrders", fields: [partnerId], references: [id])
  driverId    String?
  driver      DriverProfile? @relation("DriverOrders", fields: [driverId], references: [id])
  serviceType ServiceType
  status      OrderStatus @default(PENDING)
  totalAmount Float
  deliveryAddress String
  deliveryPosition Json?  // { lat, lng }
  note        String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  items       OrderItem[]
}

// ─────────────────────────────────────────────
// ORDER ITEM  (polymorphic: dish OR gas bottle)
// ─────────────────────────────────────────────

model OrderItem {
  id          String     @id @default(uuid())
  orderId     String
  order       Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  quantity    Int        @default(1)
  unitPrice   Float

  // Polymorphic product reference (one of the two will be set)
  dishId      String?
  dish        Dish?      @relation(fields: [dishId], references: [id])
  gasBottleId String?
  gasBottle   GasBottle? @relation(fields: [gasBottleId], references: [id])
}

// ─────────────────────────────────────────────
// SANCTION
// ─────────────────────────────────────────────

model Sanction {
  id          String       @id @default(uuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        SanctionType
  reason      String
  issuedAt    DateTime     @default(now())
  expiresAt   DateTime?
}
